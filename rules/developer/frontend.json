[
  {
    "id": "npm-cache",
    "name": "npm 全局缓存",
    "path": "~/.npm",
    "risk": "safe",
    "size_estimate": "500 MB - 5 GB",
    "impact": "删除后下载依赖包会重新从网络获取",
    "conditions": ["path_exists:~/.npm"],
    "tags": ["frontend", "npm", "package-cache"]
  },
  {
    "id": "yarn-cache",
    "name": "Yarn 缓存",
    "path": "~/Library/Caches/Yarn",
    "risk": "safe",
    "size_estimate": "500 MB - 5 GB",
    "impact": "删除后 yarn install 会重新下载",
    "conditions": ["path_exists:~/Library/Caches/Yarn"],
    "tags": ["frontend", "yarn", "package-cache"]
  },
  {
    "id": "pnpm-store",
    "name": "pnpm 全局存储",
    "path": "~/Library/pnpm/store",
    "risk": "safe",
    "size_estimate": "1-10 GB",
    "impact": "删除后 pnpm install 会重新下载依赖",
    "conditions": ["path_exists:~/Library/pnpm/store"],
    "tags": ["frontend", "pnpm", "package-cache"]
  },
  {
    "id": "nvm-versions",
    "name": "NVM 安装的 Node.js 版本",
    "path": "~/.nvm/versions/node",
    "risk": "warning",
    "size_estimate": "1-10 GB",
    "impact": "删除后需要通过 nvm install 重新下载安装 Node.js 版本，全局 npm 包也会丢失",
    "conditions": ["path_exists:~/.nvm"],
    "tags": ["frontend", "nvm", "runtime"]
  },
  {
    "id": "nvm-cache",
    "name": "NVM 下载缓存",
    "path": "~/.nvm/.cache",
    "risk": "safe",
    "size_estimate": "100 MB - 1 GB",
    "impact": "删除后 nvm install 会重新下载 Node.js 安装包",
    "conditions": ["path_exists:~/.nvm/.cache"],
    "tags": ["frontend", "nvm", "cache"]
  },
  {
    "id": "fnm-versions",
    "name": "fnm 安装的 Node.js 版本",
    "path": "~/Library/Application Support/fnm/node-versions",
    "risk": "warning",
    "size_estimate": "500 MB - 5 GB",
    "impact": "删除后需要通过 fnm install 重新下载安装",
    "conditions": ["path_exists:~/Library/Application Support/fnm"],
    "tags": ["frontend", "fnm", "runtime"]
  },
  {
    "id": "bun-install-cache",
    "name": "Bun 安装缓存",
    "path": "~/.bun/install/cache",
    "risk": "safe",
    "size_estimate": "500 MB - 5 GB",
    "impact": "删除后 bun install 会重新下载依赖",
    "conditions": ["path_exists:~/.bun"],
    "tags": ["frontend", "bun", "package-cache"]
  },
  {
    "id": "yarn-berry-cache",
    "name": "Yarn Berry (v2+) 缓存",
    "path": "~/.yarn/berry/cache",
    "risk": "safe",
    "size_estimate": "500 MB - 5 GB",
    "impact": "删除后 Yarn Berry 项目安装依赖需重新下载",
    "conditions": ["path_exists:~/.yarn/berry/cache"],
    "tags": ["frontend", "yarn", "package-cache"]
  },
  {
    "id": "playwright-browsers",
    "name": "Playwright 浏览器二进制",
    "path": "~/Library/Caches/ms-playwright",
    "risk": "safe",
    "size_estimate": "1-5 GB",
    "impact": "删除后需要 npx playwright install 重新下载浏览器",
    "conditions": ["path_exists:~/Library/Caches/ms-playwright"],
    "tags": ["frontend", "playwright", "browser-cache"]
  }
]
