[
  {
    "id": "claude-code-cache",
    "name": "Claude Code 工具缓存",
    "path": "~/.claude/.cache",
    "risk": "safe",
    "size_estimate": "100 MB - 2 GB",
    "impact": "删除后 Claude Code 会重建缓存，不影响对话历史",
    "conditions": ["path_exists:~/.claude/.cache"],
    "tags": ["agent", "claude-code", "cache"]
  },
